# package.json
cat > clickinteligente/frontend/package.json <<EOL
{
  "name": "clickinteligente-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test"
  }
}
EOL

# index.tsx
cat > clickinteligente/frontend/src/index.tsx <<EOL
import React from 'react';
import ReactDOM from 'react-dom/client';
import App from './App';
import './index.css';

const root = ReactDOM.createRoot(document.getElementById('root') as HTMLElement);
root.render(
  <React.StrictMode>
    <App />
  </React.StrictMode>
);
EOL

# App.tsx
cat > clickinteligente/frontend/src/App.tsx <<EOL
import React from 'react';
import Dashboard from './pages/Dashboard';

const App: React.FC = () => {
  return <Dashboard />;
};

export default App;
EOL

# index.css
cat > clickinteligente/frontend/src/index.css <<EOL
body { margin: 0; font-family: Arial, sans-serif; }
EOL

# Dashboard.tsx
cat > clickinteligente/frontend/src/pages/Dashboard.tsx <<EOL
import React from 'react';

const Dashboard: React.FC = () => {
  return (
    <div>
      <h1>Dashboard ClickInteligente</h1>
      <p>Bienvenido al panel</p>
    </div>
  );
};

export default Dashboard;
EOL

# public/index.html
cat > clickinteligente/frontend/public/index.html <<EOL
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ClickInteligente</title>
</head>
<body>
  <div id="root"></div>
</body>
</html>
EOL
